{
  "name": "senars-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "core",
    "nar",
    "agent",
    "ui",
    "tensor",
    "metta",
    "rl"
  ],
  "packageManager": "pnpm@10.0.0",
  "bin": {
    "senars": "./scripts/cli/senars.js"
  },
  "scripts": {
    "senars": "node scripts/cli/senars.js",
    "repl": "pnpm -C agent run repl --",
    "ui": "pnpm -C ui run dev",
    "bot": "node agent/examples/chatbot/run-intelligent-chatbot.js",
    "ui:build": "pnpm -C ui run build",
    "ui:remote": "node scripts/ui/launcher.js",
    "ui:remote:dev": "node scripts/ui/launcher.js --host 0.0.0.0",
    "ui:remote:build": "pnpm -C ui run build",
    "ui:remote:prod": "node scripts/ui/launcher.js --prod",
    "demo": "node scripts/ui/launcher.js --demo basicUsage",
    "demo:tui": "pnpm -C agent run repl -- --demo",
    "screenshots": "node scripts/utils/visualize.js --type screenshots",
    "movies": "node scripts/utils/visualize.js --type movie",
    "capture": "node scripts/utils/visualize.js",
    "composite": "node scripts/utils/generate-composite.js",
    "capture:priority": "node scripts/utils/visualize.js --type priority",
    "capture:derivations": "node scripts/utils/visualize.js --type derivations",
    "analyze": "node scripts/analysis/self-analyze.js",
    "rule-analysis": "node scripts/utils/deep_rule_analysis.js",
    "test": "pnpm run test:all",
    "test:all": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
    "test:unit": "NODE_NO_WARNINGS=1 NODE_OPTIONS=--experimental-vm-modules pnpm exec jest --config jest.unit.config.js --forceExit",
    "test:integration": "NODE_NO_WARNINGS=1 NODE_OPTIONS=--experimental-vm-modules pnpm exec jest --config jest.integration.config.js --forceExit",
    "test:e2e": "pnpm -C ui run test:e2e",
    "test:debug": "NODE_NO_WARNINGS=1 NODE_OPTIONS=--experimental-vm-modules pnpm exec jest --detectOpenHandles tests/reason/Metacognition.integration.test.js",
    "test:property": "NODE_NO_WARNINGS=1 NODE_OPTIONS=--experimental-vm-modules pnpm exec jest tests/nal/propertyBasedTests.test.js",
    "test:ui-screenshots": "pnpm -C ui run test:screenshots",
    "config:compare": "node scripts/utils/config-comparison.js",
    "data:export": "node scripts/utils/data-management.js --export",
    "data:import": "node scripts/utils/data-management.js --import",
    "data:backup": "node scripts/utils/data-management.js --backup",
    "data:restore": "node scripts/utils/data-management.js --restore",
    "data:clean": "node scripts/utils/data-management.js --clean",
    "ai:develop": "node scripts/utils/autonomous-development.js",
    "ai:tune-heuristics": "node scripts/utils/autonomous-development.js --mode tune-heuristics",
    "ai:ui-optimize": "node scripts/utils/autonomous-development.js --mode ui-optimization",
    "perf:monitor": "node scripts/utils/performance-monitor.js",
    "perf:profile": "node scripts/utils/performance-monitor.js --profile",
    "dev:workflow": "node scripts/utils/automated-dev-workflow.js",
    "dev:visual-inspection": "node scripts/utils/automated-dev-workflow.js --visual-inspection",
    "dev:tune-heuristics": "node scripts/utils/automated-dev-workflow.js --tune-heuristics",
    "dev:regression": "node scripts/utils/automated-dev-workflow.js --regression-tests",
    "agent": "pnpm exec http-server -p 8080 -o /ui/agent.html",
    "lint:patterns": "node scripts/utils/lint-patterns.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "pnpm run build:parser",
    "build:parser": "pnpm exec peggy --format es -o nar/src/parser/peggy-parser.js nar/src/parser/narsese.peggy",
    "build:browser": "pnpm exec esbuild scripts/verification/browser-test.js --bundle --format=iife --platform=browser --outfile=browser-bundle.js --log-level=info --alias:fs/promises=./ui/src/shims/mock-node.js --alias:fs=./ui/src/shims/mock-node.js --alias:path=./ui/src/shims/mock-node.js --alias:child_process=./ui/src/shims/mock-node.js --alias:os=./ui/src/shims/mock-node.js --alias:crypto=./ui/src/shims/mock-node.js --alias:url=./ui/src/shims/mock-node.js --alias:node:readline=./ui/src/shims/mock-node.js --alias:node:util=./ui/src/shims/mock-node.js --alias:node:path=./ui/src/shims/mock-node.js --alias:node:os=./ui/src/shims/mock-node.js --alias:node:crypto=./ui/src/shims/mock-node.js --alias:stream=./ui/src/shims/mock-node.js --alias:node:async_hooks=./ui/src/shims/mock-node.js --alias:node:process=./ui/src/shims/mock-node.js --alias:tty=./ui/src/shims/mock-node.js --alias:module=./ui/src/shims/mock-node.js --alias:node:module=./ui/src/shims/mock-node.js --alias:events=./ui/src/shims/mock-node.js --alias:buffer=./ui/src/shims/mock-node.js --define:import.meta.url=\"''\" --inject:./ui/src/shims/process-shim.js",
    "benchmark": "node metta/benchmark/suite.js",
    "slides:dev": "slidev slides.md",
    "slides:pdf": "slidev export slides.md"
  },
  "keywords": [
    "senars",
    "agi",
    "nars",
    "cognitive-architecture",
    "neuro-symbolic",
    "reasoning"
  ],
  "author": "Developers",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@playwright/test": "^1.59.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^10.0.1",
    "@slidev/cli": "^52.14.1",
    "@slidev/theme-default": "^0.25.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "esbuild": "^0.27.5",
    "eslint": "^10.2.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "peggy": "^5.1.0",
    "playwright": "^1.59.1",
    "playwright-chromium": "^1.59.1",
    "slidev-theme-dracula": "^0.2.0"
  }
}
