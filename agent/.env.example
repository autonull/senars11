# SeNARS Agent Configuration

# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Anthropic ───────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── LLM Provider (openai, anthropic, ollama, dummy) ────
LLM_PROVIDER=openai

# ── LLM Model Name ─────────────────────────────────────
LLM_MODEL=gpt-4o-mini

# ── Ollama (local, no key needed) ──────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── WebSocket Server ───────────────────────────────────
WS_PORT=8080
WS_HOST=0.0.0.0

# ── UI Server ──────────────────────────────────────────
PORT=5173

# ── Logging (DEBUG, INFO, WARN, ERROR) ─────────────────
LOG_LEVEL=INFO

# ── Matrix (optional) ──────────────────────────────────
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_ACCESS_TOKEN=
# MATRIX_USER_ID=@user:matrix.org

# ── Nostr (optional) ───────────────────────────────────
# NOSTR_PRIVATE_KEY=
# NOSTR_RELAYS=wss://relay.damus.io

# ── IRC (optional) ─────────────────────────────────────
# IRC_HOST=irc.quakenet.org
# IRC_PORT=6667
# IRC_NICK=SeNARchy

# ── Matrix (optional) ──────────────────────────────────
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_ACCESS_TOKEN=
# MATRIX_USER_ID=@user:matrix.org

# ── Nostr (optional) ───────────────────────────────────
